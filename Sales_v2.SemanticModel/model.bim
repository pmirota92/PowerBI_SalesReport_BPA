          },
          {
            "name": "DaysBetweenPurchases",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "dataType": "int64",
            "formatString": "0",
            "isDataTypeInferred": true,
            "isNameInferred": true,
            "lineageTag": "f3c08439-fad9-4acb-9bc2-4f0cc5bef36e",
            "sourceColumn": "[DaysBetweenPurchases]",
            "summarizeBy": "sum",
            "type": "calculatedTableColumn"
          }
        ],
        "lineageTag": "65ef00ac-eb3d-4429-a000-f9ccd4111a0c",
        "measures": [
          {
            "name": "AvgDaysBetweenPurchases",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": "AVERAGE('ProductPurchase_Diff'[DaysBetweenPurchases])",
            "lineageTag": "277e67a6-8363-4468-a63f-60b88cfebd63"
          }
        ],
        "partitions": [
          {
            "name": "ProductPurchase_Diff",
            "mode": "import",
            "source": {
              "expression": [
                "",
                "ADDCOLUMNS(",
                "    SUMMARIZE(",
                "        fact_sales, ",
                "        fact_sales[Product ID], ",
                "        fact_sales[Order Date]",
                "    ),",
                "    \"PreviousPurchaseDate\", ",
                "    CALCULATE(",
                "        MAX(fact_sales[Order Date]),",
                "        FILTER(",
                "            fact_sales,",
                "            fact_sales[Product ID] = EARLIER(fact_sales[Product ID]) &&",
                "            fact_sales[Order Date] < EARLIER(fact_sales[Order Date])",
                "        )",
                "    ),",
                "    \"DaysBetweenPurchases\", ",
                "    DATEDIFF(",
                "        CALCULATE(",
                "            MAX(fact_sales[Order Date]),",
                "            FILTER(",
                "                fact_sales,",
                "                fact_sales[Product ID] = EARLIER(fact_sales[Product ID]) &&",
                "                fact_sales[Order Date] < EARLIER(fact_sales[Order Date])",
                "            )",
                "        ),",
                "        fact_sales[Order Date],",
                "        DAY",
                "    )",
                ")",
                ""
              ],
              "type": "calculated"
            }
          }
        ]
      },
