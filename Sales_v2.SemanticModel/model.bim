        "partitions": [
          {
            "name": "fact_sales",
            "mode": "import",
            "queryGroup": "fact_tbl",
            "source": {
              "expression": [
                "let",
                "    Source = Orders,",
                "    FactSales = Table.SelectColumns(Source, {\"Order ID\", \"Order Date\", \"Ship Date\",\"Ship Mode\", \"Customer ID\", \"Product ID\",\"Product Name\",\"Postal Code\",\"City\", \"Sales\", \"Quantity\",\"Discount\", \"Profit\"}),",
                "    AddGeoID = Table.AddColumn(FactSales, \"GeoID\", each [Postal Code] & \" - \" & [City]),",
                "    #\"Changed Type\" = Table.TransformColumnTypes(AddGeoID,{{\"Order ID\", type text}, {\"Order Date\", type date}, {\"Ship Date\", type date}, {\"Ship Mode\", type text}, {\"Customer ID\", type text}, {\"Product ID\", type text}, {\"Product Name\", type text}, {\"Postal Code\", Int64.Type}, {\"Sales\", type number}, {\"Quantity\", type number}, {\"Discount\", type number}, {\"Profit\", type number}, {\"GeoID\", type text}}),",
                "    #\"Removed Columns\" = Table.RemoveColumns(#\"Changed Type\",{\"Postal Code\", \"City\"})",
                "in",
                "    #\"Removed Columns\""
              ],
              "type": "m"
            }
          }
        ]
      },
