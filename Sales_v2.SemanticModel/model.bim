            "name": "CustomerAvgDaysBetweenPurchases",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": "AVERAGE('CustomerPurchase_Diff'[DaysBetweenPurchases])",
            "lineageTag": "c82d6592-79fa-4112-8348-b74e650e8032"
          }
        ],
        "partitions": [
          {
            "name": "CustomerPurchase_Diff",
            "mode": "import",
            "source": {
              "expression": [
                "",
                "ADDCOLUMNS(",
                "    SUMMARIZE(",
                "        fact_sales, ",
                "        fact_sales[Customer ID], ",
                "        fact_sales[Order Date]",
                "    ),",
                "    \"PreviousPurchaseDate\", ",
                "    CALCULATE(",
                "        MAX(fact_sales[Order Date]),",
                "        FILTER(",
                "            fact_sales,",
                "            fact_sales[Customer ID] = EARLIER(fact_sales[Customer ID]) &&",
                "            fact_sales[Order Date] < EARLIER(fact_sales[Order Date])",
                "        )",
                "    ),",
                "    \"DaysBetweenPurchases\", ",
                "    DATEDIFF(",
                "        CALCULATE(",
                "            MAX(fact_sales[Order Date]),",
                "            FILTER(",
                "                fact_sales,",
                "                fact_sales[Customer ID] = EARLIER(fact_sales[Customer ID]) &&",
                "                fact_sales[Order Date] < EARLIER(fact_sales[Order Date])",
                "            )",
                "        ),",
                "        fact_sales[Order Date],",
                "        DAY",
                "    )",
                ")"
              ],
              "type": "calculated"
            }
          }
        ]
