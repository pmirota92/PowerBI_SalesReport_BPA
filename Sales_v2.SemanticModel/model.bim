                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "dataType": "double",
            "expression": [
              "",
              "DIVIDE(fact_sales[Sales], fact_sales[Quantity])"
            ],
            "isDataTypeInferred": true,
            "lineageTag": "c6002f7e-9f26-46f4-a892-781a90846f20",
